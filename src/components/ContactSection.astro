---
import { siteConfig } from '../data/siteConfig';
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Jetzt Angebot anfragen',
  subtitle = 'Kontaktieren Sie uns für eine unverbindliche Beratung – wir melden uns innerhalb von 24 Stunden.',
} = Astro.props;

const id = Math.random().toString(36).slice(2, 8);
const allLeistungen = (await getCollection('leistungen')).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<section class="contact-section">
  <div class="container">
    <div class="contact-card" id={`contact-${id}`}>

      <!-- Left: info panel -->
      <div class="contact-card__info">
        <div class="info-blur"></div>

        <div class="info-top">
          <span class="info-badge">
            <span class="info-badge__dot"></span>
            Schnelle Antwort
          </span>
          <h2>{title}</h2>
          <p>{subtitle}</p>
        </div>

        <div class="info-contacts">
          <a href={`tel:${siteConfig.telefon.replace(/\s/g, '')}`} class="info-contact-row">
            <span class="info-contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17z"/></svg>
            </span>
            <div>
              <span class="info-contact-label">Telefon</span>
              <span class="info-contact-value">{siteConfig.telefon}</span>
            </div>
            <span class="info-contact-arrow">
              <svg class="arrow-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
          <a href={`mailto:${siteConfig.email}`} class="info-contact-row">
            <span class="info-contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <div>
              <span class="info-contact-label">E-Mail</span>
              <span class="info-contact-value">{siteConfig.email}</span>
            </div>
            <span class="info-contact-arrow">
              <svg class="arrow-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact-card__form">
        <form class="cform" id={`form-${id}`} novalidate>

          <div class="cform-row">
            <div class="cform-group">
              <label for={`name-${id}`}>Name *</label>
              <input type="text" id={`name-${id}`} name="name" required autocomplete="name" placeholder="Max Mustermann" />
            </div>
            <div class="cform-group">
              <label for={`email-${id}`}>E-Mail *</label>
              <input type="email" id={`email-${id}`} name="email" required autocomplete="email" placeholder="max@beispiel.de" />
            </div>
          </div>

          <div class="cform-row">
            <div class="cform-group">
              <label for={`telefon-${id}`}>Telefon</label>
              <input type="tel" id={`telefon-${id}`} name="telefon" autocomplete="tel" placeholder="+49 911 …" />
            </div>
            <div class="cform-group">
              <label for={`leistung-${id}`}>Gewünschte Leistung</label>
              <select id={`leistung-${id}`} name="leistung">
                <option value="">Bitte wählen …</option>
                {allLeistungen.map((l) => (
                  <option value={l.slug}>{l.data.title}</option>
                ))}
                <option value="OTH">Sonstiges</option>
              </select>
            </div>
          </div>

          <div class="cform-group">
            <label for={`nachricht-${id}`}>Nachricht *</label>
            <textarea
              id={`nachricht-${id}`}
              name="nachricht"
              rows="4"
              maxlength="1000"
              required
              placeholder="Beschreiben Sie kurz Ihr Vorhaben …"
            ></textarea>
            <span class="cform-counter"><span class="cform-count">0</span>/1000</span>
          </div>

          <div class="cform-checkbox">
            <input type="checkbox" id={`dsgvo-${id}`} name="datenschutz" required />
            <label for={`dsgvo-${id}`}>
              Ich akzeptiere die <a href="/datenschutz">Datenschutzbestimmungen</a> und stimme der Verarbeitung meiner Daten zu. *
            </label>
          </div>

          <!-- Honeypot -->
          <div style="display:none" aria-hidden="true">
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>

          <button type="submit" class="cform-submit btn btn-accent">
            <span class="cform-submit__text">Anfrage senden →</span>
            <span class="cform-submit__sending" hidden>Wird gesendet …</span>
          </button>
        </form>

        <div class="cform-success" id={`success-${id}`} hidden>
          <div class="cform-success__icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <p class="cform-success__title">Nachricht erfolgreich gesendet!</p>
          <p class="cform-success__sub">Vielen Dank – wir melden uns innerhalb von 24 Stunden bei Ihnen.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>('.cform').forEach((form) => {
    const wrapper = form.closest('[id^="contact-"]') as HTMLElement;
    const successEl = wrapper?.querySelector<HTMLElement>('[id^="success-"]');
    const textarea = form.querySelector<HTMLTextAreaElement>('textarea');
    const counter = form.querySelector<HTMLElement>('.cform-count');
    const submitBtn = form.querySelector<HTMLButtonElement>('.cform-submit');
    const submitText = submitBtn?.querySelector<HTMLElement>('.cform-submit__text');
    const submitSending = submitBtn?.querySelector<HTMLElement>('.cform-submit__sending');

    // Character counter
    textarea?.addEventListener('input', () => {
      if (counter) counter.textContent = String(textarea.value.length);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }

      if (submitBtn) submitBtn.disabled = true;
      if (submitText) submitText.hidden = true;
      if (submitSending) submitSending.hidden = false;

      const data = new FormData(form);
      const leistungSelect = form.querySelector<HTMLSelectElement>('select[name="leistung"]');
      const selectedOption = leistungSelect?.selectedOptions[0];
      const leistungId = selectedOption?.value || '';
      const leistungName = leistungId ? selectedOption?.textContent?.trim() : '';
      const leadOrigin = new URLSearchParams(window.location.search).get('lead_origin');

      try {
        const res = await fetch('https://api2.smalt.eu/api/v1/leads/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            customer_name: data.get('name'),
            email: data.get('email') || undefined,
            phone_number: data.get('telefon') || undefined,
            required_service: data.get('nachricht') || undefined,
            service_interested_in: leistungId ? { id: leistungId, name: leistungName } : undefined,
            acquisition_medium: leadOrigin ? 'organic' : 'website',
            acquisition_source: leadOrigin ? 'google_my_business' : 'partner_website',
            partner_name: { name: 'Voltario Elektrotechnik' },
            sub_channel_source_detail: 'Website Form',
          }),
        });

        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        // Reset the button state (even though the form will be hidden)
        if (submitBtn) submitBtn.disabled = false;
        if (submitText) submitText.hidden = false;
        if (submitSending) submitSending.hidden = true;

        // Hide the form — use style.display because .cform has display: flex
        // which overrides the user-agent [hidden] rule
        form.style.display = 'none';
        if (successEl) successEl.hidden = false;
      } catch {
        if (submitBtn) submitBtn.disabled = false;
        if (submitText) submitText.hidden = false;
        if (submitSending) submitSending.hidden = true;
        alert('Fehler beim Senden. Bitte versuchen Sie es erneut.');
      }
    });
  });
</script>

<style>
  .contact-section {
    padding: var(--space-3xl) 0;
  }

  /* Card */
  .contact-card {
    display: grid;
    grid-template-columns: 2fr 3fr;
    border-radius: 1.5rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 860px) {
    .contact-card { grid-template-columns: 1fr; }
  }

  /* ---- LEFT PANEL ---- */
  .contact-card__info {
    background: var(--color-primary);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-xl);
    position: relative;
    overflow: hidden;
  }

  /* Decorative glow */
  .info-blur {
    position: absolute;
    top: -5rem;
    right: -5rem;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    background: hsl(218, 70%, 45% / 0.12);
    filter: blur(60px);
    pointer-events: none;
  }

  .info-top { position: relative; }

  /* Badge */
  .info-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: hsl(218, 80%, 70% / 0.18);
    border: 1px solid hsl(218, 80%, 70% / 0.25);
    color: hsl(218, 85%, 78%);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.9rem;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-lg);
  }

  .info-badge__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: hsl(218, 85%, 78%);
    animation: pulse-dot 2s infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.75); }
  }

  .info-top h2 {
    color: var(--color-white);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    margin-bottom: var(--space-sm);
    line-height: 1.25;
  }

  .info-top p {
    color: rgba(255,255,255,0.65);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  /* Contact rows */
  .info-contacts {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    position: relative;
  }

  .info-contact-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 0.85rem 1rem;
    border-radius: var(--radius-md);
    background: rgba(255,255,255,0.06);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .info-contact-row:hover {
    background: rgba(255,255,255,0.12);
  }

  .info-contact-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: hsl(218, 85%, 78%);
  }

  .info-contact-row div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
  }

  .info-contact-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.4);
  }

  .info-contact-value {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-white);
  }

  .info-contact-arrow {
    color: rgba(255,255,255,0.3);
    font-size: 0.9rem;
    transition: transform var(--transition-fast), color var(--transition-fast);
  }

  .info-contact-row:hover .info-contact-arrow {
    transform: translateX(3px);
    color: hsl(218, 85%, 78%);
  }

  /* ---- RIGHT PANEL (form) ---- */
  .contact-card__form {
    background: var(--color-bg);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
  }

  /* Form */
  .cform {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cform-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  @media (max-width: 560px) {
    .cform-row { grid-template-columns: 1fr; }
  }

  .cform-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    position: relative;
  }

  .cform-group label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-dark);
  }

  .cform-group input,
  .cform-group select,
  .cform-group textarea {
    padding: 0.7rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-dark);
    background: var(--color-bg);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    width: 100%;
  }

  .cform-group input:focus,
  .cform-group select:focus,
  .cform-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px hsl(218, 70%, 45% / 0.10),
                0 1px 4px hsl(218, 70%, 45% / 0.08);
  }

  .cform-group textarea { resize: none; }

  .cform-counter {
    position: absolute;
    bottom: 0.6rem;
    right: 0.75rem;
    font-size: 10px;
    color: var(--color-text-light);
    pointer-events: none;
  }

  /* Checkbox */
  .cform-checkbox {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .cform-checkbox input[type="checkbox"] {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  .cform-checkbox label {
    font-size: var(--text-xs);
    color: var(--color-text-light);
    line-height: 1.6;
    cursor: pointer;
  }

  .cform-checkbox a {
    color: var(--color-accent-dark);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Submit */
  .cform-submit {
    width: 100%;
    justify-content: center;
    height: 3rem;
    font-size: var(--text-base);
    font-weight: 700;
    box-shadow: 0 4px 20px hsl(218, 70%, 45% / 0.25);
    transition: all var(--transition-base);
  }

  .cform-submit:hover {
    box-shadow: 0 6px 28px hsl(218, 70%, 45% / 0.35);
    transform: translateY(-1px);
  }

  .cform-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  /* Success */
  .cform-success[hidden] { display: none; }

  .cform-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.75rem;
    flex: 1;
    padding: var(--space-2xl) var(--space-md);
    animation: successFadeIn 0.5s ease both;
  }

  .cform-success__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, hsl(218, 70%, 45% / 0.12), hsl(218, 70%, 45% / 0.04));
    border: 1px solid hsl(218, 70%, 45% / 0.25);
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    animation: successPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s both;
  }

  .cform-success__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-dark);
    margin: 0;
  }

  .cform-success__sub {
    font-size: var(--text-base);
    color: var(--color-text-light);
    line-height: 1.6;
    max-width: 360px;
    margin: 0;
  }

  @keyframes successFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes successPop {
    0%   { opacity: 0; transform: scale(0.6); }
    60%  { opacity: 1; transform: scale(1.08); }
    100% { opacity: 1; transform: scale(1); }
  }
</style>
