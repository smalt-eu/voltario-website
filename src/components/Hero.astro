---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
  image?: string;
  imageAlt?: string;
  eyebrow?: string;
  heroPhoto?: string;
  heroPhotoAlt?: string;
  googleReviewRating?: string;
  googleReviewLabel?: string;
  googleReviewHref?: string;
}

const {
  title,
  subtitle,
  ctaText = 'Kontakt aufnehmen',
  ctaHref = '/kontakt',
  ctaSecondaryText,
  ctaSecondaryHref,
  image,
  imageAlt = 'Hero Bild',
  eyebrow,
  heroPhoto,
  heroPhotoAlt = '',
  googleReviewRating,
  googleReviewLabel = 'Sterne',
  googleReviewHref,
} = Astro.props;

const ratingNumber = googleReviewRating ? parseFloat(googleReviewRating) : 0;
const filledStars = Math.round(ratingNumber);
---

<section class:list={['hero', { 'hero--split': heroPhoto }]} style={image ? `--hero-image: url('${image}')` : ''}>
  <div class="hero__overlay"></div>
  <div class="container hero__inner">
    <div class="hero__content">
      {googleReviewRating && (
        <a
          class="hero__google-badge"
          href={googleReviewHref ?? '#'}
          target={googleReviewHref ? '_blank' : undefined}
          rel={googleReviewHref ? 'noopener noreferrer' : undefined}
          aria-label={`Google Bewertung: ${googleReviewRating} ${googleReviewLabel}`}
        >
          <span class="hero__google-badge__logo" aria-hidden="true">
            <svg viewBox="0 0 48 48" width="18" height="18">
              <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3c-1.6 4.7-6 8-11.3 8-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.2 7.9 3l5.7-5.7C34 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.4-.4-3.5z"/>
              <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16 18.9 13 24 13c3.1 0 5.8 1.2 7.9 3l5.7-5.7C34 6.1 29.3 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
              <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2C29.2 35 26.7 36 24 36c-5.3 0-9.7-3.3-11.3-8l-6.5 5C9.6 39.6 16.2 44 24 44z"/>
              <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.3-4.1 5.6l6.2 5.2C37 36.6 44 31 44 24c0-1.3-.1-2.4-.4-3.5z"/>
            </svg>
          </span>
          <span class="hero__google-badge__stars" aria-hidden="true">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg viewBox="0 0 20 20" width="16" height="16" class:list={['hero__google-badge__star', { 'hero__google-badge__star--filled': i < filledStars }]}>
                <path d="M10 1.5l2.7 5.5 6 .9-4.3 4.2 1 6-5.4-2.8-5.4 2.8 1-6L1.3 7.9l6-.9z" />
              </svg>
            ))}
          </span>
          <span class="hero__google-badge__text">{googleReviewRating} {googleReviewLabel}</span>
        </a>
      )}
      {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
      <h1 class="hero__title" set:html={title} />
      {subtitle && <p class="hero__subtitle">{subtitle}</p>}
      <div class="hero__actions">
        <a href={ctaHref} class="btn btn-accent">{ctaText}</a>
        {ctaSecondaryText && ctaSecondaryHref && (
          <a href={ctaSecondaryHref} class="btn btn-outline-white">
            {ctaSecondaryText}
          </a>
        )}
      </div>
    </div>
    {heroPhoto && (
      <div class="hero__photo">
        <div class="hero__photo-glow"></div>
        <img src={heroPhoto} alt={heroPhotoAlt} />
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: flex-end;
    background-color: var(--color-primary-dark);
    background-image: var(--hero-image, none);
    background-size: cover;
    background-position: center calc(50% + var(--scroll-y, 0px) * 0.3);
    padding-top: var(--navbar-height, 72px);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: var(--hero-overlay);
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-3xl);
  }

  .hero__content {
    max-width: 680px;
  }

  /* ============================================================
     Split layout (hero with foreground photo)
     ============================================================
     Goals:
     - Hero exactly 100vh tall — fits perfectly above the fold
     - Photo bottom-anchored to the hero's bottom edge
     - Photo fully visible inside the viewport (no clipping)
     - Text vertically centered next to the photo
     ============================================================ */
  .hero--split {
    --hero-content-height: calc(100vh - var(--navbar-height, 72px));
    align-items: stretch;
    min-height: 100vh;
    padding-top: var(--navbar-height, 72px);
    overflow: hidden;
    isolation: isolate;
    background-color: transparent !important;
    background-image:
      radial-gradient(ellipse 80% 60% at 80% 30%, hsl(218, 55%, 22%) 0%, transparent 55%),
      radial-gradient(ellipse 60% 50% at 15% 90%, hsl(210, 40%, 18%) 0%, transparent 60%),
      linear-gradient(135deg, hsl(210, 30%, 7%) 0%, hsl(210, 25%, 11%) 55%, hsl(210, 22%, 9%) 100%) !important;
  }

  /* Hide the default overlay element for split layout */
  .hero--split .hero__overlay {
    display: none;
  }

  /* Grid pattern overlay */
  .hero--split::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 75%);
    pointer-events: none;
    z-index: -1;
  }

  /* Soft navy glow accent in upper right */
  .hero--split::after {
    content: '';
    position: absolute;
    top: -20%;
    right: -8%;
    width: 800px;
    height: 800px;
    border-radius: 50%;
    background: radial-gradient(circle, hsl(218, 70%, 45% / 0.22) 0%, hsl(218, 70%, 45% / 0.06) 45%, transparent 70%);
    filter: blur(20px);
    pointer-events: none;
    z-index: -1;
  }

  /* Inner grid: 2 columns, photo bottom-anchored, text vertically centered */
  .hero--split .hero__inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: end;
    gap: var(--space-xl);
    padding-top: 0;
    padding-bottom: 0;
    height: 100%;
  }

  /* Text column */
  .hero--split .hero__content {
    max-width: 620px;
    justify-self: start;
    align-self: center;
    padding-bottom: 0;
  }

  /* Google review badge */
  .hero__google-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.9rem 0.5rem 0.65rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-full);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-decoration: none;
    color: var(--color-white);
    margin-bottom: var(--space-lg);
    transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }

  .hero__google-badge:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.22);
    transform: translateY(-1px);
  }

  .hero__google-badge__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--color-white);
    flex-shrink: 0;
  }

  .hero__google-badge__stars {
    display: inline-flex;
    gap: 1px;
  }

  .hero__google-badge__star {
    fill: rgba(255, 255, 255, 0.25);
  }

  .hero__google-badge__star--filled {
    fill: #FBBC04;
  }

  .hero__google-badge__text {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: -0.01em;
  }

  .hero--split .hero__eyebrow {
    margin-bottom: var(--space-md);
  }

  .hero--split .hero__title {
    margin-bottom: var(--space-md);
    letter-spacing: -0.02em;
  }

  .hero--split .hero__subtitle {
    max-width: 540px;
    margin-bottom: var(--space-xl);
  }

  /* Photo column: bottom-anchored, image flush with hero bottom edge */
  .hero__photo {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    align-self: end;
    overflow: visible;
    min-width: 0;
  }

  .hero__photo-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 95%;
    height: 75%;
    border-radius: 50%;
    background: radial-gradient(circle at center, hsl(218, 70%, 45% / 0.28) 0%, hsl(218, 70%, 45% / 0.10) 45%, transparent 70%);
    filter: blur(70px);
    pointer-events: none;
  }

  /*
    Photo sizing — the key rules:
    - height capped at the available content area height (= viewport - navbar)
      so it's ALWAYS fully visible at exactly 100vh
    - width: auto so the natural square aspect ratio is preserved
    - bottom-anchored via flex align-items: flex-end + display: block
    - max-width: none so the square image is allowed to overflow its grid column
      (the parent has overflow: visible and the section has overflow: hidden)
  */
  .hero__photo img {
    position: relative;
    display: block;
    width: auto;
    height: var(--hero-content-height);
    max-height: var(--hero-content-height);
    max-width: none;
    object-fit: contain;
    object-position: bottom center;
    filter: drop-shadow(0 12px 40px rgba(0, 0, 0, 0.45));
  }

  @media (max-width: 900px) {
    .hero--split {
      min-height: auto;
      padding-top: var(--navbar-height, 72px);
    }

    .hero--split .hero__inner {
      grid-template-columns: 1fr;
      text-align: left;
      padding-top: var(--space-2xl);
      padding-bottom: var(--space-2xl);
      gap: var(--space-2xl);
    }

    .hero--split .hero__title {
      font-size: clamp(1.75rem, 6vw, 2.25rem);
      margin-bottom: var(--space-md);
    }

    .hero--split .hero__subtitle {
      font-size: var(--text-base);
      max-width: 100%;
      margin-bottom: var(--space-lg);
    }

    /* Content first, photo below on mobile */
    .hero__photo {
      order: 1;
      width: 100%;
      max-width: 360px;
      margin: 0 auto;
      align-self: center;
      overflow: visible;
      aspect-ratio: 1 / 1;
    }

    .hero__photo-glow {
      inset: 0;
      transform: scale(1);
    }

    .hero__photo img {
      width: 100%;
      height: 100%;
      max-height: 45vh;
      max-width: 100%;
      object-fit: contain;
    }

    .hero--split .hero__content {
      max-width: 100%;
      padding-bottom: 0;
    }

    .hero--split .hero__actions {
      justify-content: flex-start;
    }

    .hero--split .hero__subtitle {
      max-width: 100%;
    }
  }

  .hero__eyebrow {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .hero__title {
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.12;
    margin-bottom: var(--space-lg);
  }

  .hero__subtitle {
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
    max-width: 500px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }

  /* Entrance animations */
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__eyebrow { animation: heroFadeUp 0.6s ease both; animation-delay: 0.1s; }
    .hero__title   { animation: heroFadeUp 0.7s ease both; animation-delay: 0.25s; }
    .hero__subtitle{ animation: heroFadeUp 0.7s ease both; animation-delay: 0.4s; }
    .hero__actions { animation: heroFadeUp 0.7s ease both; animation-delay: 0.55s; }
    .hero__photo   { animation: heroFadeIn 0.9s ease both; animation-delay: 0.2s; }
  }
</style>

<script>
  // Parallax scroll — updates CSS custom property on root
  window.addEventListener('scroll', () => {
    document.documentElement.style.setProperty('--scroll-y', `${window.scrollY}px`);
  }, { passive: true });
</script>
