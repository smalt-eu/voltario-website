---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/siteConfig';
import { team } from '../data/team';
import { timeline } from '../data/timeline';
import { certifications } from '../data/certifications';
---

<Layout
  title="Über uns"
  description={`Seit über ${siteConfig.yearsInBusiness} Jahren steht ${siteConfig.firmenname} für Qualität und Verlässlichkeit in ${siteConfig.stadt}. Lernen Sie unser Team kennen.`}
>
  <!-- Page Hero -->
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Startseite</a>
        <span class="sep">/</span>
        <span class="current">Über uns</span>
      </nav>
      <h1>Über uns</h1>
      <p>Familienunternehmen. Handwerkskunst. Bayerische Werte.</p>
    </div>
  </div>

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div class="intro-grid">
        <div class="intro-text">
          <span class="eyebrow">Seit über {siteConfig.yearsInBusiness} Jahren</span>
          <h2>{siteConfig.firmenname} – Ihr Partner in {siteConfig.stadt}.</h2>
          <div class="divider divider--left"></div>
          <p>{siteConfig.description}</p>
        </div>
        <div class="intro-image">
          <img src="/images/voltario-logo.png" alt={`${siteConfig.firmenname} Logo`} loading="lazy" />
          <div class="intro-badge">
            <span class="intro-badge__number">{siteConfig.yearsInBusiness}+</span>
            <span class="intro-badge__label">Jahre Erfahrung</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video section hidden until Voltario provides a video URL -->

  <!-- Values -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Was uns ausmacht</span>
        <h2>Unsere Werte</h2>
        <div class="divider"></div>
        <p>Prinzipien, die jede Entscheidung bei {siteConfig.firmenname} leiten.</p>
      </div>
      <div class="values-grid" data-stagger>
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526"/><circle cx="12" cy="8" r="6"/></svg>
          </div>
          <h3>Qualität</h3>
          <p>
            Als Elektro-Fachbetrieb arbeiten wir normgerecht und mit zertifizierter
            Markentechnik von SMA, E3DC, Kostal, Fronius und Viessmann. Jede Installation
            wird sauber ausgeführt, sorgfältig dokumentiert und fachgerecht abgenommen.
          </p>
        </div>
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/></svg>
          </div>
          <h3>Verlässlichkeit</h3>
          <p>
            Wir melden uns innerhalb von 24 Stunden, halten Termine und kommunizieren
            transparent – von der ersten Anfrage bis zur Inbetriebnahme. Ein fester
            Ansprechpartner begleitet Sie durch das gesamte Projekt.
          </p>
        </div>
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></svg>
          </div>
          <h3>Nachhaltigkeit</h3>
          <p>
            Wir treiben die Energiewende aktiv voran – mit Photovoltaik, Batteriespeichern,
            Wärmepumpen und Wallboxen. Jedes Projekt ist ein Schritt in Richtung
            Energieunabhängigkeit und CO₂-Reduktion.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline – hidden for now -->
  {false && (
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Unsere Geschichte</span>
        <h2>Meilensteine</h2>
        <div class="divider"></div>
      </div>
      <div class="timeline">
        {timeline.map((item) => (
          <div class="timeline-item" data-animate="fade-left">
            <div class="timeline-year">{item.year}</div>
            <div class="timeline-content">
              <h4>{item.title}</h4>
              <p>{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  )}

  <!-- Team -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Die Menschen dahinter</span>
        <h2>Unser Geschäftsführer</h2>
        <div class="divider"></div>
      </div>
      <div class="team-solo">
        <div class="team-solo__image">
          <div class="team-solo__glow"></div>
          <img src="/images/voltario-logo.png" alt={`${siteConfig.firmenname} Logo`} loading="lazy" />
        </div>
        <div class="team-solo__bio">
          <h3>{team[0].name}</h3>
          <p class="team-solo__role">{team[0].role}</p>
          {team[0].bio && <p class="team-solo__text">{team[0].bio}</p>}
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications & Numbers -->
  <section class="section">
    <div class="container">
      <div class="facts-grid">
        <div class="facts-text">
          <span class="eyebrow">Zahlen & Zertifikate</span>
          <h2>Qualität, die man messen kann.</h2>
          <div class="divider divider--left"></div>
          <p>
            Unsere Arbeit wird nicht nur von zufriedenen Kunden bestätigt,
            sondern auch durch unabhängige Prüfstellen und Zertifizierungen.
          </p>
          <ul class="cert-list">
            {certifications.map((cert) => (
              <li>
                <span class="cert-icon">✓</span>
                <div>
                  <strong>{cert}</strong>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="facts-numbers">
          <div class="fact-number">
            <span class="fact-number__value">{siteConfig.projectCount}+</span>
            <span class="fact-number__label">Abgeschlossene Projekte</span>
          </div>
          <div class="fact-number">
            <span class="fact-number__value">{siteConfig.employeeCount}+</span>
            <span class="fact-number__label">Mitarbeitende</span>
          </div>
          <div class="fact-number">
            <span class="fact-number__value">{siteConfig.yearsInBusiness}</span>
            <span class="fact-number__label">Jahre am Markt</span>
          </div>
          <div class="fact-number">
            <span class="fact-number__value">{siteConfig.locationCount}</span>
            <span class="fact-number__label">Standorte</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Intro */
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  @media (max-width: 900px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }

  .intro-text .eyebrow {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .intro-text h2 { margin-bottom: var(--space-sm); }

  .intro-text p {
    color: var(--color-text-light);
    margin-bottom: var(--space-md);
    font-size: var(--text-lg);
    line-height: 1.8;
  }

  .intro-text p:last-child { margin-bottom: 0; }

  .intro-image {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-alt);
    border-radius: var(--radius-xl);
    padding: var(--space-3xl);
    min-height: 520px;
    box-shadow: var(--shadow-sm);
  }

  .intro-image img {
    width: 100%;
    max-width: 360px;
    height: auto;
    object-fit: contain;
  }

  .intro-badge {
    position: absolute;
    bottom: -1.5rem;
    left: -1.5rem;
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-lg) var(--space-xl);
    box-shadow: var(--shadow-lg);
    text-align: center;
  }

  .intro-badge__number {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1;
  }

  .intro-badge__label {
    font-size: var(--text-sm);
    opacity: 0.85;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .intro-badge {
      bottom: 1rem;
      left: 1rem;
    }
  }

  /* Values */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  @media (max-width: 768px) {
    .values-grid { grid-template-columns: 1fr; }
  }

  .value-card {
    position: relative;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl) var(--space-xl);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .value-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--accent-gradient);
    opacity: 0;
    transform: scaleX(0.4);
    transform-origin: left;
    transition: opacity var(--transition-base), transform var(--transition-base);
  }

  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }

  .value-card:hover::before {
    opacity: 1;
    transform: scaleX(1);
  }

  .value-card__icon {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, hsl(218, 70%, 45% / 0.10) 0%, hsl(218, 70%, 45% / 0.04) 100%);
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
    transition: transform var(--transition-base), background var(--transition-base);
  }

  .value-card__icon::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    border: 1px solid hsl(218, 70%, 45% / 0.15);
    pointer-events: none;
  }

  .value-card:hover .value-card__icon {
    background: var(--accent-gradient);
    color: var(--color-white);
    transform: scale(1.05);
  }

  .value-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
    color: var(--color-dark);
  }

  .value-card p {
    font-size: var(--text-base);
    color: var(--color-text-light);
    line-height: 1.8;
  }

  /* Timeline */
  .timeline {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 92px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
    position: relative;
  }

  .timeline-item:last-child { margin-bottom: 0; }

  .timeline-year {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 800;
    color: var(--color-primary);
    text-align: right;
    padding-top: 2px;
    position: relative;
  }

  .timeline-year::after {
    content: '';
    position: absolute;
    right: -1.35rem;
    top: 8px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 3px solid var(--color-white);
    box-shadow: 0 0 0 2px var(--color-primary);
  }

  @media (prefers-reduced-motion: no-preference) {
    .timeline-year::after {
      transform: scale(0);
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.15s;
    }

    .timeline-item.is-visible .timeline-year::after {
      transform: scale(1);
    }
  }

  .timeline-content {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .timeline-item:last-child .timeline-content {
    border-bottom: none;
  }

  .timeline-content h4 {
    font-size: var(--text-lg);
    margin-bottom: 0.4rem;
  }

  .timeline-content p {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.7;
  }

  @media (max-width: 560px) {
    .timeline::before { left: 60px; }

    .timeline-item { grid-template-columns: 60px 1fr; gap: var(--space-md); }

    .timeline-year { font-size: var(--text-base); }

    .timeline-year::after { right: -1rem; }
  }

  /* Video section */
  .video-wrapper {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.10),
      0 24px 48px rgba(0, 0, 0, 0.14);
    background: var(--color-primary-dark);
  }

  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Team solo – logo on the left, single bio on the right */
  .team-solo {
    display: grid;
    grid-template-columns: minmax(280px, 1fr) 1.2fr;
    gap: var(--space-3xl);
    align-items: center;
    max-width: 960px;
    margin: 0 auto;
  }

  .team-solo__image {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl);
  }

  .team-solo__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, hsl(218, 70%, 40% / 0.14) 0%, transparent 65%);
    filter: blur(40px);
    pointer-events: none;
  }

  .team-solo__image img {
    position: relative;
    width: 100%;
    max-width: 320px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 10px 28px rgba(0, 0, 0, 0.12));
  }

  .team-solo__bio {
    display: flex;
    flex-direction: column;
  }

  .team-solo__bio h3 {
    font-size: var(--text-3xl);
    margin-bottom: 0.25rem;
    color: var(--color-dark);
  }

  .team-solo__role {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    text-transform: uppercase;
  }

  .team-solo__text {
    font-size: var(--text-base);
    color: var(--color-text-light);
    line-height: 1.75;
    max-width: 520px;
  }

  @media (max-width: 900px) {
    .team-solo {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
      text-align: center;
    }

    .team-solo__image img {
      max-width: 260px;
    }

    .team-solo__role,
    .team-solo__text {
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* Facts */
  .facts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  @media (max-width: 900px) {
    .facts-grid { grid-template-columns: 1fr; }
  }

  .facts-text .eyebrow {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .facts-text h2 { margin-bottom: var(--space-sm); }

  .facts-text > p {
    color: var(--color-text-light);
    margin-bottom: var(--space-xl);
    font-size: var(--text-lg);
  }

  .cert-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cert-list li {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .cert-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .cert-list strong {
    display: block;
    font-size: var(--text-base);
    color: var(--color-dark);
  }

  .cert-list span {
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .facts-numbers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .fact-number {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    text-align: center;
  }

  .fact-number__value {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .fact-number__label {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-light);
    font-weight: 500;
  }

</style>
