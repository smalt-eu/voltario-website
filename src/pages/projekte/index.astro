---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const projekte = (await getCollection('projekte')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Collect unique leistungen for filter
const leistungenIds = [...new Set(projekte.map((p) => p.data.leistung))];

const leistungenData = await getCollection('leistungen');
const leistungMap = Object.fromEntries(leistungenData.map((l) => [l.slug, l.data.title]));
---

<Layout
  title="Referenzprojekte"
  description="Abgeschlossene Bauprojekte der Baumeister GmbH – Hochbau, Sanierung und Dacharbeiten in ganz Bayern."
>
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Startseite</a>
        <span class="sep">/</span>
        <span class="current">Projekte</span>
      </nav>
      <h1>Referenzprojekte</h1>
      <p>Jedes Projekt ist ein Zeugnis unserer Arbeit. Überzeugen Sie sich selbst.</p>
    </div>
  </div>

  <!-- Filter bar -->
  <div class="filter-bar">
    <div class="container filter-bar__inner">
      <span class="filter-label">Filtern nach:</span>
      <button class="filter-btn filter-btn--active" data-filter="all">Alle</button>
      {leistungenIds.map((id) => (
        <button class="filter-btn" data-filter={id}>
          {leistungMap[id] ?? id}
        </button>
      ))}
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="grid-3" id="projekte-grid">
        {projekte.map((p) => (
          <div data-leistung={p.data.leistung} class="projekt-item">
            <Card
              variant="project"
              title={p.data.title}
              description={p.data.description}
              image={p.data.coverImage || ''}
              href={`/projekte/${p.slug}`}
              meta={p.data.standort}
              badge={leistungMap[p.data.leistung] ?? p.data.leistung}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.projekt-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      buttons.forEach((b) => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');

      items.forEach((item) => {
        const match = filter === 'all' || item.dataset.leistung === filter;
        item.style.display = match ? '' : 'none';
      });
    });
  });
</script>

<style>
  .filter-bar {
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-md) 0;
    position: sticky;
    top: 72px;
    z-index: 10;
  }

  .filter-bar__inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-light);
    margin-right: 0.5rem;
  }

  .filter-btn {
    padding: 0.35rem 1rem;
    border-radius: var(--radius-full);
    border: 1.5px solid var(--color-border);
    background: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .filter-btn--active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-white);
  }
</style>
