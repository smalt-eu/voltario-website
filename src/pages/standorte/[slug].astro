---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import BreadcrumbJsonLd from '../../components/BreadcrumbJsonLd.astro';
import { getCollection } from 'astro:content';
import { staedte } from '../../data/staedte';
import { getLeistungIcon } from '../../data/leistungIcons';

export async function getStaticPaths() {
  return staedte.map((s) => ({
    params: { slug: s.slug },
    props: { stadt: s },
  }));
}

const { stadt } = Astro.props;

// Office contact info (always from the single standort entry)
const standorte = await getCollection('standorte');
const office = standorte[0];

// Projects in this city
const alleProjekte = await getCollection('projekte');
const lokaleP = alleProjekte
  .filter((p) => p.data.standort === stadt.name)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const leistungenData = await getCollection('leistungen');
const leistungMap = Object.fromEntries(leistungenData.map((l) => [l.slug, l.data.title]));
const leistungenSorted = leistungenData.sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title={`Voltario Elektrotechnik GmbH in ${stadt.name}`}
  description={`Elektroinstallation, Smart Home, Photovoltaik & Wallbox in ${stadt.name} (${stadt.region}) – vom Elektro-Ingenieursbetrieb aus Berlin. 24h-Rückmeldung, persönlicher Service.`}
>
  <BreadcrumbJsonLd items={[
    { name: 'Startseite', url: '/' },
    { name: 'Standort', url: '/standorte' },
    { name: stadt.name, url: `/standorte/${stadt.slug}` },
  ]} />
  <!-- Page Hero -->
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Startseite</a>
        <span class="sep">/</span>
        <a href="/standorte">Standort</a>
        <span class="sep">/</span>
        <span class="current">{stadt.name}</span>
      </nav>
      <div class="region-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>{stadt.region}</span>
      </div>
      <h1>Voltario Elektrotechnik<br/>in {stadt.name}</h1>
      <p>{stadt.beschreibung}</p>
    </div>
  </div>

  <!-- Benefits strip -->
  <div class="benefits-strip">
    <div class="container benefits-strip__inner">
      <div class="benefit">
        <div class="benefit__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div>
          <strong>24h-Rückmeldung</strong>
          <span>Wir melden uns innerhalb eines Werktags auf jede Anfrage.</span>
        </div>
      </div>
      <div class="benefit">
        <div class="benefit__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <strong>Elektro-Ingenieursbetrieb</strong>
          <span>Normgerecht, zertifiziert und mit voller Verantwortung.</span>
        </div>
      </div>
      <div class="benefit">
        <div class="benefit__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div>
          <strong>Region {stadt.region}</strong>
          <span>Persönlicher Ansprechpartner aus Ihrer Nähe.</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <section class="section">
    <div class="container">
      <div class="stadt-layout">

        <div class="stadt-main">
          <span class="eyebrow">Leistungen vor Ort</span>
          <h2>Was wir in {stadt.name} anbieten</h2>
          <p>
            In {stadt.name} und Umgebung führen wir alle unsere Leistungen durch –
            von Elektroinstallationen und Smart-Home-Systemen über Photovoltaik und
            Batteriespeicher bis hin zu Wallbox-Installationen und zertifizierten
            Elektroprüfungen. Als Elektro-Ingenieursbetrieb aus Berlin begleiten wir
            Ihr Projekt von der Planung bis zur Inbetriebnahme.
          </p>

          <div class="leistungen-grid">
            {leistungenSorted.map((l) => (
              <a href={`/leistungen/${l.slug}`} class="leistung-card">
                <span class="leistung-card__icon" set:html={getLeistungIcon(l.data.icon)} />
                <div class="leistung-card__body">
                  <strong>{l.data.title}</strong>
                  <span>{l.data.description}</span>
                </div>
                <span class="leistung-card__arrow">
                  <svg class="arrow-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="stadt-sidebar">
          {office && (
            <div class="contact-box">
              <h3>Kontakt aufnehmen</h3>
              <p>Haben Sie ein Projekt in {stadt.name}? Rufen Sie uns an oder schreiben Sie uns.</p>
              <ul class="contact-list">
                <li>
                  <span class="cli"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17z"/></svg></span>
                  <a href={`tel:${office.data.phone.replace(/\s/g,'')}`}>{office.data.phone}</a>
                </li>
                <li>
                  <span class="cli"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></span>
                  <a href={`mailto:${office.data.email}`}>{office.data.email}</a>
                </li>
                <li>
                  <span class="cli"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></span>
                  <span>{office.data.address}</span>
                </li>
                <li>
                  <span class="cli"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
                  <span>{office.data.hours}</span>
                </li>
              </ul>
              <a href="/kontakt" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:1rem;">
                Nachricht senden
              </a>
            </div>
          )}

          <div class="back-box">
            <a href="/standorte" class="back-link">
            <svg class="arrow-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="transform: scaleX(-1)"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Alle Städte im Einzugsgebiet
          </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Local projects -->
  {lokaleP.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Vor Ort</span>
          <h2>Unsere Projekte in {stadt.name}</h2>
          <div class="divider"></div>
        </div>
        <div class="grid-3">
          {lokaleP.map((p) => (
            <Card
              variant="project"
              title={p.data.title}
              description={p.data.description}
              image={p.data.coverImage}
              href={`/projekte/${p.slug}`}
              meta={leistungMap[p.data.leistung] ?? p.data.leistung}
            />
          ))}
        </div>
        <div style="text-align:center;margin-top:2.5rem;">
          <a href="/projekte" class="btn btn-outline">Alle Projekte ansehen</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section">
    <div class="container" style="text-align:center;">
      <h2>Projekt in {stadt.name} geplant?</h2>
      <p style="color:var(--color-text-light);max-width:520px;margin:1rem auto 2rem;font-size:var(--text-lg);">
        Kontaktieren Sie uns für ein unverbindliches Beratungsgespräch – wir melden uns innerhalb von 24 Stunden.
      </p>
      <a href="/kontakt" class="btn btn-primary">Kostenlos anfragen</a>
    </div>
  </section>
</Layout>

<style>
  /* Region pill in hero */
  .region-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.9rem;
    background: hsl(218, 70%, 45% / 0.15);
    border: 1px solid hsl(218, 70%, 45% / 0.30);
    color: hsl(218, 75%, 72%);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  /* Benefits strip */
  .benefits-strip {
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-xl) 0;
  }

  .benefits-strip__inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  @media (max-width: 900px) {
    .benefits-strip__inner { grid-template-columns: 1fr; gap: var(--space-md); }
  }

  .benefit {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .benefit__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: hsl(218, 70%, 45% / 0.10);
    color: var(--color-accent);
  }

  .benefit > div:last-child {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .benefit strong {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-dark);
  }

  .benefit span {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.5;
  }

  /* Layout */
  .stadt-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-2xl);
    align-items: flex-start;
  }

  @media (max-width: 960px) {
    .stadt-layout { grid-template-columns: 1fr; }
  }

  .stadt-main .eyebrow {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .stadt-main h2 { margin-bottom: var(--space-md); }

  .stadt-main > p {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: var(--space-2xl);
    max-width: 640px;
  }

  /* Leistungen card grid */
  .leistungen-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 700px) {
    .leistungen-grid { grid-template-columns: 1fr; }
  }

  .leistung-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-dark);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    position: relative;
  }

  .leistung-card:hover {
    transform: translateY(-2px);
    border-color: transparent;
    box-shadow: var(--shadow-md);
  }

  .leistung-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: hsl(218, 70%, 45% / 0.10);
    color: var(--color-accent);
    transition: background var(--transition-base), color var(--transition-base);
  }

  .leistung-card:hover .leistung-card__icon {
    background: var(--accent-gradient);
    color: var(--color-white);
  }

  .leistung-card__icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .leistung-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 0;
  }

  .leistung-card__body strong {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.3;
  }

  .leistung-card__body span {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .leistung-card__arrow {
    color: var(--color-text-light);
    flex-shrink: 0;
    margin-top: 0.6rem;
    transition: transform var(--transition-fast), color var(--transition-fast);
  }

  .leistung-card:hover .leistung-card__arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }

.cli {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: rgba(255,255,255,0.5);
    margin-top: 1px;
  }

  /* Sidebar */
  .stadt-sidebar {
    position: sticky;
    top: var(--sticky-top);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-box {
    background: var(--color-primary);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    color: rgba(255,255,255,0.85);
  }

  .contact-box h3 {
    color: var(--color-white);
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }

  .contact-box > p {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-top: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .contact-list li {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .contact-list a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .contact-list a:hover { text-decoration: underline; }

  .contact-list span:last-child { color: rgba(255,255,255,0.75); }

  .back-box {
    text-align: center;
    padding: var(--space-md);
  }

  .back-box a {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    text-decoration: none;
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .back-box a:hover { color: var(--color-primary); }
</style>
