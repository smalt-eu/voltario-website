---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { staedte } from '../../data/staedte';

const standorte = (await getCollection('standorte')).sort(
  (a, b) => a.data.order - b.data.order
);
const office = standorte[0];

// Group cities by region
const regionen = staedte.reduce<Record<string, typeof staedte>>((acc, s) => {
  if (!acc[s.region]) acc[s.region] = [];
  acc[s.region].push(s);
  return acc;
}, {});
---

<Layout
  title="Standort & Einzugsgebiet"
  description="Voltario Elektrotechnik GmbH – ansässig in Berlin, tätig in ganz Berlin und Brandenburg. Alle bedienten Bezirke und Städte auf einen Blick."
>
  <!-- Hero -->
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Startseite</a>
        <span class="sep">/</span>
        <span class="current">Standort</span>
      </nav>
      <h1>Unser Standort &<br/>Einzugsgebiet</h1>
      <p>Wir sind in Berlin-Pankow zuhause und für Sie in ganz Berlin sowie im Brandenburger Umland im Einsatz.</p>
    </div>
  </div>

  <!-- Office card -->
  {office && (
    <section class="office-section">
      <div class="container">
        <div class="office-card">
          <div class="office-card__map">
            <iframe
              src={`https://www.google.com/maps?q=${encodeURIComponent(office.data.address)}&output=embed`}
              width="100%"
              height="100%"
              style="border:0;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Karte ${office.data.city}`}
            ></iframe>
          </div>

          <div class="office-card__body">
            <div class="office-card__label">Hauptsitz</div>
            <h2>{office.data.city}</h2>

            <div class="office-details">
              <div class="office-detail">
                <div class="office-detail__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></div>
                <div>
                  <strong>Adresse</strong>
                  <span>{office.data.address}</span>
                </div>
              </div>
              <div class="office-detail">
                <div class="office-detail__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
                <div>
                  <strong>Öffnungszeiten</strong>
                  <span>{office.data.hours}</span>
                </div>
              </div>
              <div class="office-detail">
                <div class="office-detail__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17z"/></svg></div>
                <div>
                  <strong>Telefon</strong>
                  <a href={`tel:${office.data.phone.replace(/\s/g,'')}`}>{office.data.phone}</a>
                </div>
              </div>
              <div class="office-detail">
                <div class="office-detail__icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
                <div>
                  <strong>E-Mail</strong>
                  <a href={`mailto:${office.data.email}`}>{office.data.email}</a>
                </div>
              </div>
            </div>

            <div class="office-card__actions">
              <a href="/kontakt" class="btn btn-accent">Kontakt aufnehmen</a>
              <a href={`tel:${office.data.phone.replace(/\s/g,'')}`} class="btn btn-outline-white">
                Direkt anrufen
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Radius strip -->
  <div class="radius-strip">
    <div class="container radius-strip__inner">
      <div class="radius-stat">
        <span class="radius-stat__number">80</span>
        <span class="radius-stat__label">km Radius</span>
      </div>
      <div class="radius-divider"></div>
      <div class="radius-stat">
        <span class="radius-stat__number">{staedte.length}</span>
        <span class="radius-stat__label">Städte & Gemeinden</span>
      </div>
      <div class="radius-divider"></div>
      <div class="radius-stat">
        <span class="radius-stat__number">5</span>
        <span class="radius-stat__label">Kreise & Regionen</span>
      </div>
      <div class="radius-divider"></div>
      <p class="radius-text">
        Ihr Ort ist nicht dabei? Kein Problem —
        <a href="/kontakt">fragen Sie uns einfach.</a>
      </p>
    </div>
  </div>

  <!-- Cities by region -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Einzugsgebiet</span>
        <h2>Alle bedienten Städte</h2>
        <div class="divider"></div>
        <p>Klicken Sie auf eine Stadt, um mehr über unsere Projekte und Leistungen vor Ort zu erfahren.</p>
      </div>

      {Object.entries(regionen).map(([region, cities]) => (
        <div class="region-block">
          <h3 class="region-title">{region}</h3>
          <div class="cities-grid">
            {cities.map((s) => (
              <a href={`/standorte/${s.slug}`} class="city-card">
                <div class="city-card__check">✓</div>
                <div class="city-card__text">
                  <strong>{s.name}</strong>
                  <span>{s.beschreibung.slice(0, 72)}…</span>
                </div>
                <span class="city-card__arrow">
                  <svg class="arrow-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--alt">
    <div class="container" style="text-align:center;">
      <h2>Ihr Ort. Unser Einsatz.</h2>
      <p style="color:var(--color-text-light);max-width:540px;margin:1rem auto 2rem;font-size:var(--text-lg);">
        Ob Photovoltaik, Wallbox, Wärmepumpe oder Elektroinstallation – wir kommen zu Ihnen und beraten Sie kostenlos vor Ort.
      </p>
      <a href="/kontakt" class="btn btn-primary">Termin vereinbaren</a>
    </div>
  </section>
</Layout>

<style>
  /* ---- OFFICE SECTION ---- */
  .office-section {
    padding: var(--space-3xl) 0;
  }

  .office-card {
    display: grid;
    grid-template-columns: 1fr 480px;
    min-height: 500px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
  }

  @media (max-width: 960px) {
    .office-card { grid-template-columns: 1fr; }
  }

  .office-card__map {
    position: relative;
    min-height: 400px;
  }

  .office-card__map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 960px) {
    .office-card__map { min-height: 280px; }
    .office-card__map iframe { position: relative; height: 280px; }
  }

  .office-card__body {
    background: var(--color-primary);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-lg);
  }

  .office-card__label {
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .office-card__body h2 {
    font-size: clamp(1.8rem, 3vw, 2.75rem);
    color: var(--color-white);
    margin: 0;
  }

  /* Details list */
  .office-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-top: var(--space-lg);
  }

  .office-detail {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .office-detail__icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    margin-top: 2px;
    color: rgba(255,255,255,0.6);
  }

  .office-detail div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .office-detail strong {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.45);
  }

  .office-detail span {
    font-size: var(--text-base);
    color: rgba(255,255,255,0.85);
  }

  .office-detail a {
    font-size: var(--text-base);
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .office-detail a:hover { text-decoration: underline; }

  .office-card__actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-top: var(--space-lg);
  }

  /* ---- RADIUS STRIP ---- */
  .radius-strip {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-xl) 0;
  }

  .radius-strip__inner {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .radius-stat {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .radius-stat__number {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .radius-stat__label {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    font-weight: 500;
  }

  .radius-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .radius-divider { display: none; }
  }

  .radius-text {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-left: auto;
  }

  .radius-text a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .radius-text a:hover { text-decoration: underline; }

  /* ---- REGIONS & CITIES ---- */
  .region-block {
    margin-bottom: var(--space-2xl);
  }

  .region-block:last-child { margin-bottom: 0; }

  .region-title {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--color-border);
  }

  .cities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  .city-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
    color: var(--color-dark);
  }

  .city-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .city-card__check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--accent-gradient);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: 800;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .city-card__text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .city-card__text strong {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-dark);
    line-height: 1.2;
  }

  .city-card:hover .city-card__text strong {
    color: var(--color-primary);
  }

  .city-card__text span {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .city-card__arrow {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    flex-shrink: 0;
    transition: transform var(--transition-fast), color var(--transition-fast);
    margin-top: 4px;
  }

  .city-card:hover .city-card__arrow {
    transform: translateX(4px);
    color: var(--color-primary);
  }
</style>
