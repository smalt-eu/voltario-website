---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import BreadcrumbJsonLd from '../../components/BreadcrumbJsonLd.astro';
import { getCollection } from 'astro:content';
import { staedte } from '../../data/staedte';
import { getFaqsForSlug } from '../../data/faqs';

export async function getStaticPaths() {
  const leistungen = await getCollection('leistungen');
  return leistungen.map((l) => ({
    params: { slug: l.slug },
    props: { leistung: l },
  }));
}

const { leistung } = Astro.props;
const { Content } = await leistung.render();

// Fetch related projects for this service
const alleProjekte = await getCollection('projekte');
const zugehoerigeP = alleProjekte
  .filter((p) => p.data.leistung === leistung.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Top cities for internal linking (first 8)
const topCities = staedte.slice(0, 8);

// FAQ data (may be undefined for services without FAQs)
const pageFaqs = getFaqsForSlug(leistung.slug);

// Service JSON-LD + optional FAQPage JSON-LD
const pageJsonLd: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: leistung.data.title,
    description: leistung.data.description,
    provider: {
      '@type': 'Electrician',
      name: 'Voltario Elektrotechnik GmbH',
      url: 'https://voltario-elektrotechnik.de',
    },
    areaServed: staedte.map((s) => ({ '@type': 'City', name: s.name })),
    url: `https://voltario-elektrotechnik.de/leistungen/${leistung.slug}`,
  },
];

if (pageFaqs) {
  pageJsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: pageFaqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: f.answer,
      },
    })),
  });
}
---

<Layout
  title={leistung.data.title}
  description={leistung.data.description}
  image={leistung.data.image}
  jsonLd={pageJsonLd}
>
  <BreadcrumbJsonLd items={[
    { name: 'Startseite', url: '/' },
    { name: 'Leistungen', url: '/leistungen' },
    { name: leistung.data.title, url: `/leistungen/${leistung.slug}` },
  ]} />
  <!-- Page Hero -->
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Startseite</a>
        <span class="sep">/</span>
        <a href="/leistungen">Leistungen</a>
        <span class="sep">/</span>
        <span class="current">{leistung.data.title}</span>
      </nav>
      <h1>{leistung.data.title}</h1>
      <p>{leistung.data.description}</p>
    </div>
  </div>

  <!-- Content + Features -->
  <section class="section">
    <div class="container">
      <div class="leistung-layout">
        <!-- Main content -->
        <article class="prose leistung-content">
          <Content />
        </article>

        <!-- Sidebar -->
        <aside class="leistung-sidebar">
          <div class="sidebar-card">
            <h3>Leistungsumfang</h3>
            <ul class="feature-list">
              {leistung.data.features.map((f) => (
                <li>
                  <span class="check">✓</span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="sidebar-card sidebar-card--cta">
            <h3>Interesse geweckt?</h3>
            <p>Kontaktieren Sie uns für ein unverbindliches Beratungsgespräch.</p>
            <a href="/kontakt" class="btn btn-primary" style="width: 100%; justify-content: center;">
              Jetzt anfragen
            </a>
            <a href="tel:+499111234560" class="btn btn-outline" style="width: 100%; justify-content: center; margin-top: 0.5rem;">
              +49 911 123 456 0
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Cover image -->
  {leistung.data.image && (
    <div class="leistung-image">
      <div class="container">
        <img
          src={leistung.data.image}
          alt={`${leistung.data.title} – Voltario Elektrotechnik GmbH Berlin`}
          loading="lazy"
        />
      </div>
    </div>
  )}

  <!-- FAQ section (only when FAQs exist for this service) -->
  {pageFaqs && (
    <section class="section section--alt">
      <div class="container container--narrow">
        <div class="section-header">
          <span class="eyebrow">Häufige Fragen</span>
          <h2>Das sagen unsere Kunden am häufigsten</h2>
          <div class="divider"></div>
          <p>Antworten auf die häufigsten Fragen rund um {leistung.data.title}.</p>
        </div>
        <div class="faq-list">
          {pageFaqs.map((f, i) => (
            <details class="faq-item" open={i === 0}>
              <summary>
                <span>{f.question}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <p>{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Region cities (internal linking for SEO) -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">In Ihrer Region</span>
        <h2>{leistung.data.title} in Ihrer Nähe</h2>
        <div class="divider"></div>
        <p>Wir sind als Elektro-Ingenieursbetrieb in ganz Berlin und Brandenburg für Sie im Einsatz.</p>
      </div>
      <div class="region-cities">
        {topCities.map((s) => (
          <a href={`/standorte/${s.slug}`} class="region-city">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{leistung.data.title} in {s.name}</span>
          </a>
        ))}
      </div>
      <div style="text-align: center; margin-top: 2rem;">
        <a href="/standorte" class="btn btn-outline">Alle Städte im Einzugsgebiet</a>
      </div>
    </div>
  </section>

  <!-- Related projects -->
  {zugehoerigeP.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="section-header">
          <span class="eyebrow">Referenzen</span>
          <h2>Abgeschlossene Projekte</h2>
          <div class="divider"></div>
          <p>Beispiele aus unserem Leistungsbereich {leistung.data.title}.</p>
        </div>
        <div class="grid-3">
          {zugehoerigeP.map((p) => (
            <Card
              variant="project"
              title={p.data.title}
              description={p.data.description}
              image={p.data.coverImage}
              href={`/projekte/${p.id}`}
              meta={p.data.standort}
            />
          ))}
        </div>
        <div style="text-align: center; margin-top: 2.5rem;">
          <a href="/projekte" class="btn btn-outline">Alle Projekte ansehen</a>
        </div>
      </div>
    </section>
  )}

  <!-- Reonic PV configurator hidden until Voltario provides client+frontend IDs -->

  <!-- Other services -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <h2>Weitere Leistungen</h2>
      <p style="color: var(--color-text-light); margin: 1rem 0 2rem;">
        Entdecken Sie unser gesamtes Leistungsportfolio.
      </p>
      <a href="/leistungen" class="btn btn-outline">Alle Leistungen ansehen</a>
    </div>
  </section>
</Layout>

<style>

  .leistung-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-2xl);
    align-items: flex-start;
  }

  @media (max-width: 900px) {
    .leistung-layout {
      grid-template-columns: 1fr;
    }
  }

  .leistung-content {
    max-width: none;
  }

  /* Sidebar */
  .leistung-sidebar {
    position: sticky;
    top: var(--sticky-top);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .sidebar-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .sidebar-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
    color: var(--color-dark);
  }

  .sidebar-card--cta {
    background: var(--color-primary);
    border-color: transparent;
    color: rgba(255,255,255,0.85);
  }

  .sidebar-card--cta h3 { color: var(--color-white); }

  .sidebar-card--cta p {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--space-md);
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .feature-list li {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .check {
    color: var(--color-primary);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Cover image */
  .leistung-image {
    background: var(--color-bg-alt);
    padding: 0 0 var(--space-3xl);
  }

  .leistung-image img {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  /* FAQ accordion */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .faq-item {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .faq-item[open] {
    border-color: hsl(218, 70%, 45% / 0.30);
    box-shadow: var(--shadow-sm);
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: var(--space-lg) var(--space-xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-dark);
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary:hover { color: var(--color-accent-dark); }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--color-accent);
    transition: transform var(--transition-base);
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-item p {
    padding: 0 var(--space-xl) var(--space-lg);
    font-size: var(--text-base);
    color: var(--color-text-light);
    line-height: 1.75;
    margin: 0;
  }

  /* Region cities grid */
  .region-cities {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-sm);
  }

  .region-city {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.1rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-dark);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .region-city svg {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .region-city:hover {
    background: var(--color-white);
    border-color: var(--color-accent);
    color: var(--color-accent-dark);
    transform: translateY(-1px);
  }

  /* Reonic configurator section */
  .reonic-section {
    position: relative;
    padding: var(--space-3xl) 0;
    background: linear-gradient(135deg, hsl(210, 25%, 8%) 0%, hsl(210, 20%, 14%) 50%, hsl(218, 45%, 18%) 100%);
    overflow: hidden;
  }

  .reonic-section .section-header .eyebrow {
    color: hsl(218, 80%, 62%);
  }

  .reonic-section .section-header h2 {
    color: var(--color-white);
  }

  .reonic-section .section-header p {
    color: rgba(255, 255, 255, 0.65);
  }

  .reonic-section .divider {
    background: linear-gradient(to right, hsl(218, 70%, 45%) 0 16px, rgba(255,255,255,0.15) 16px);
  }

  .reonic-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse at 20% 50%, hsl(218, 70%, 45% / 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, hsl(210, 60%, 40% / 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .reonic-wrapper {
    background: var(--color-white);
    border-radius: var(--radius-xl);
    padding: var(--space-lg);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.12),
      0 24px 48px rgba(0, 0, 0, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 768px) {
    .reonic-wrapper {
      padding: var(--space-md);
      border-radius: var(--radius-lg);
    }
  }
</style>
